n = int(input())

results = []

for _ in range(n):
    a, b, x, y = map(int, input().split())

    pairs_a2 = min(a, y)  
    remaining_a = a - pairs_a2  
    pairs_1 = min(remaining_a + b, x)  
    total1 = pairs_a2 + pairs_1

    pairs_b1 = min(b, x)  
    remaining_x = x - pairs_b1  
    pairs_a = min(a, remaining_x + y)  
    total2 = pairs_b1 + pairs_a

    results.append(max(total1, total2))

print(*results)
