h, w = map(int, input().split())

matrix = []
for i in range(h):
    row = list(map(int, input().split()))
    matrix.append(row)

min_row = h
max_row = 0
min_col = w
max_col = 0

for i in range(h):
    for j in range(w):
        if matrix[i][j] == 1:
            if i < min_row:
                min_row = i
            if i > max_row:
                max_row = i
            if j < min_col:
                min_col = j
            if j > max_col:
                max_col = j

top_left_row = min_row - 1
top_left_col = min_col - 1
bot_right_row = max_row + 1
bot_right_col = max_col + 1

print(top_left_row, top_left_col)  
print(bot_right_row, bot_right_col)  
